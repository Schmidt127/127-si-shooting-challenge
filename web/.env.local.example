# Copy to web/.env.local for local development. Never commit .env.local.
#
# For UI work against the DEV base, set AIRTABLE_BASE_ID to the dev base ID.
# Vercel production always uses the production base ID.

AIRTABLE_API_TOKEN=
# For UI work against DEV, use: AIRTABLE_BASE_ID=appTetnuCZlCZdTCT
AIRTABLE_BASE_ID=appn84sqPw03zEbTT

NEXT_PUBLIC_BASE_PATH=/shoot
NEXT_PUBLIC_LANDING_URL=https://www.hoopchallenges.com
NEXT_PUBLIC_SITE_URL=https://www.hoopchallenges.com/shoot
