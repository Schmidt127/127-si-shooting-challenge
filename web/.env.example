# Airtable (server-side only — never expose token to the browser)
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=

# Optional: restrict preview deployments (middleware + /api/airtable)
# Visit once: https://your-preview.vercel.app/?site_access_token=YOUR_TOKEN
SITE_ACCESS_TOKEN=

# Public site URL (used in metadata and deployment notes)
# Local: http://localhost:3000  |  Production: https://hoopchallenges.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Game Manual — public Adobe Document Cloud / Acrobat share link (embedded on /game-manual)
# Example: https://acrobat.adobe.com/id/urn:aaid:sc:US:...
NEXT_PUBLIC_GAME_MANUAL_URL=
