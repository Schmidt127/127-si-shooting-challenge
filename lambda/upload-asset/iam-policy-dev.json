{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3PutDevUploadPrefix",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::shooting-challenge-assets/shooting-challenge/*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-2:*:log-group:/aws/lambda/127si-dev-shooting-challenge-asset-upload:*"
    }
  ]
}
