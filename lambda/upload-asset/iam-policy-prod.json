{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteShootingChallengeAssets",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:HeadObject"],
      "Resource": "arn:aws:s3:::shooting-challenge-assets/*"
    },
    {
      "Sid": "ListShootingChallengeAssets",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::shooting-challenge-assets"
    }
  ]
}
