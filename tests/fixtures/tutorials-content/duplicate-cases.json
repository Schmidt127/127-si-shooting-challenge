    },
    {
      "id": "linked_homework",
      "expect": ["orphan"]
    },
    {
      "id": "linked_learning_activity",
      "expect": ["orphan"]
    },
    {
      "id": "published_versus_unpublished",
      "expect": ["conflicting", "probable_duplicate", "exact_duplicate"]
