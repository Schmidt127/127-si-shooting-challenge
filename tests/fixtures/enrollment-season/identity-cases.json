  "scenarios": [
    {
      "scenarioId": "exact_returning_athlete",
      "enrollment": {
        "enrollment_id": "recNew1",
        "athlete_first_name": "Alice",
        "athlete_last_name": "Anderson",
        "parent_email": "parent.anderson@example.com",
        "athlete_email": "alice@example.com"
      },
      "expectedStatus": "matched",
      "expectedMethod": "formula-match-key",
      "expectedAthleteId": "recAthAlice"
    },
    {
      "scenarioId": "same_name_same_parent",
      "enrollment": {
        "enrollment_id": "recNew2",
        "athlete_first_name": "  ALICE ",
        "athlete_last_name": "Anderson",
        "parent_email": "Parent.Anderson@example.com",
        "athlete_email": "alice.new@example.com"
      },
      "expectedStatus": "matched",
      "expectedMethod": "formula-match-key",
      "expectedAthleteId": "recAthAlice",
      "notes": "Whitespace/capitalization normalized; athlete email change ignored by 001"
    },
    {
      "scenarioId": "same_name_different_parent",
      "enrollment": {
        "enrollment_id": "recNew3",
        "athlete_first_name": "Alice",
        "athlete_last_name": "Anderson",
        "parent_email": "brand.new.parent@example.com"
      },
      "expectedStatus": "create_candidate",
      "expectedMethod": "none",
      "expectWarningSubstring": "different parent email"
    },
    {
      "scenarioId": "changed_athlete_email",
      "enrollment": {
        "enrollment_id": "recNew4",
        "athlete_first_name": "Alice",
        "athlete_last_name": "Anderson",
        "parent_email": "parent.anderson@example.com",
        "athlete_email": "totally-new-athlete-email@example.com"
      },
      "expectedStatus": "matched",
      "expectedAthleteId": "recAthAlice",
      "notes": "Athlete email is not part of match key"
    },
    {
      "scenarioId": "changed_parent_email",
      "enrollment": {
        "enrollment_id": "recNew5",
        "athlete_first_name": "Alice",
        "athlete_last_name": "Anderson",
        "parent_email": "new.parent.email@example.com",
        "athlete_email": "alice@example.com"
      },
      "expectedStatus": "create_candidate",
      "expectedMethod": "none",
      "notes": "IDENTITY RISK: parent email change creates a new Athlete under 001"
    },
    {
      "scenarioId": "spelling_difference",
      "enrollment": {
        "enrollment_id": "recNew6",
        "athlete_first_name": "Alyce",
