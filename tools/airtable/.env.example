# Copy to .env in this folder and fill in values.
# Never commit .env to GitHub.
#
# Create token: https://airtable.com/create/tokens
# Required scope: schema.bases:read (for this base)
# Optional: data.records:read (for --include-record-audits)

AIRTABLE_TOKEN=patXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Production (default for close-out scripts that target live data)
BASE_ID=appn84sqPw03zEbTT
# Development — set BASE_ID to dev when exporting/testing dev schema
# DEV_BASE_ID=appTetnuCZlCZdTCT
# Aliases also accepted by export_airtable_schema.py:
# AIRTABLE_API_TOKEN=pat...
# AIRTABLE_BASE_ID=app...
#
# C-013 DEV S3 proof (c013_dev_s3_upload_proof.py --confirm-write) — never commit:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-2
# S3_BUCKET=shooting-challenge-assets
#
# C-013 DEV Lambda Function URL tests + rotation (local only — never commit):
# UPLOAD_WEBHOOK_SECRET=<matches Lambda env>
# LAMBDA_FUNCTION_URL=https://....lambda-url.us-east-2.on.aws/
# LAMBDA_FUNCTION_NAME=127si-upload-asset-dev
# Optional one-time PAT rotation file (gitignored): .env.new-token
# Optional:
# BASE_NAME=127 SI Shooting Challenge
