    "D1": "Feedback row linked once",
    "D2": "Base XP field set",
    "D3": "VIDEO_SUBMISSION|{vfId} once",
    "D4": "Steal-guard error; no reassignment",
    "D5": "Update/repair same Event only"
  },
  "expected_output": {
    "source_key": "VIDEO_SUBMISSION|{{video_feedback}}",
    "xp_event_count_for_key": 1,
    "steal_guard": "error_or_manual_review"
  },
  "cleanup": [
    "Uncheck Ready for XP Automation? after pass",
    "Retain Event for L1 battery if scheduled"
  ],
  "rollback": [
    "If Event stolen: restore original VF link; escalate"
  ],
  "evidence_location": "docs/v2/evidence/YYYY-MM-DD-D{n}-{enrollmentId}.md"
}
