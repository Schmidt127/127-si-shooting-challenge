  "pre_test_state": {
    "require": [
      "Video upload on submission or C-020 Video scenario",
      "Video Feedback row linked once before 114",
      "Ready for XP Automation? for D3"
    ]
  },
  "records_to_create_shape": {
    "Video Feedback": {
      "Enrollment": ["{{enrollment}}"],
