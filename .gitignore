# Secrets (never commit)
.env
.env.local
**/.env
**/.env.local
**/.env.new-token
**/c013-prod-deploy-session.local.json

# Generated operational previews (previously tracked files remain tracked)
_preview/
**/_preview/**

# Unsanitized Make exports stay local; commit only reviewed templates/blueprints
make/exports/
make/blueprints/*.local.json
make/blueprints/*-unsanitized.json

# Local Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Local schema export temp output (use airtable/schema/snapshots/ instead)
_schema/

# Next.js web app
web/node_modules/
web/.next/
web/out/
web/.vercel/
.vercel

# Lambda build artifacts (source in lambda/upload-asset/)
lambda/upload-asset/dist/

# V2 DEV runbook local operator state (owned record IDs; never commit tokens)
tools/airtable/v2_dev_runbook/.run-state/
