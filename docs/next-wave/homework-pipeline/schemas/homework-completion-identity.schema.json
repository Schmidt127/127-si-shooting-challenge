{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoopchallenges.com/schemas/homework-completion-identity.json",
  "title": "HomeworkCompletionIdentity",
  "type": "object",
  "additionalProperties": false,
  "required": ["enrollmentId", "homeworkAssignmentId", "itemSlot", "responseKind"],
  "properties": {
    "enrollmentId": {
      "type": "string",
      "pattern": "^rec[a-zA-Z0-9]{14}$"
    },
    "homeworkAssignmentId": {
      "type": "string",
      "pattern": "^rec[a-zA-Z0-9]{14}$",
      "description": "FBC Curriculum - SYNC record id (Homework link)"
    },
    "itemSlot": {
      "type": "string",
      "description": "HW1 | HW2 | WRITTEN | QUIZ | LA | HWn"
    },
    "submissionId": {
      "type": ["string", "null"],
      "pattern": "^rec[a-zA-Z0-9]{14}$"
    },
    "weekId": {
      "type": ["string", "null"],
      "pattern": "^rec[a-zA-Z0-9]{14}$"
    },
    "responseKind": {
      "type": "string",
      "enum": ["file", "written", "quiz", "learning_activity"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "responseKind": { "const": "file" } }
      },
      "then": {
        "required": ["submissionId"]
      }
    }
  ]
}
