{
  "name": "Shooting Challenge - DEV - Zoom Recording Approval Email - 117f - v1",
  "description": "C-025 DEV sanitized Make scenario reference for 117f v1.2.0 Zoom recording approval email. Recreate in Make UI from this module map. No webhook URLs or secrets included. Scenario must remain OFF until Mike reviews module map + recipient mapping.",
  "c025": {
    "backlog": "C-025",
    "automationNumber": "117f",
    "scriptVersion": "v1.2.0",
    "baseId": "appTetnuCZlCZdTCT",
    "environment": "DEV",
    "sanitized": true,
    "containsOperationalSecrets": false,
    "importMode": "reference-template",
    "requiredState": "OFF until module map + recipient mapping reviewed",
    "contractDoc": "docs/deploy-checklists/C-025-117f-dev-make-scenario-contract.md",
    "deploymentChecklist": "docs/deploy-checklists/C-025-117f-dev-make-deployment-checklist.md",
    "offlineHelpers": "make/lib/c025-117f-make-scenario.js",
    "samplePayload": "make/test-payloads/c025-117f-zoom-recording-approved.sample.json",
    "scenarioVariables": [
      {
        "name": "sendMode",
        "placeholder": "test",
        "type": "text",
        "secret": false,
        "description": "Must be test for all DEV validation. live only after Mike approval."
      },
      {
        "name": "testRecipientEmail",
        "placeholder": "REPLACE_WITH_MIKE_CONTROLLED_TEST_INBOX",
        "type": "text",
        "secret": true,
        "description": "Mike-controlled test inbox only. Never a parent address. Never commit the real value."
      },
      {
        "name": "replyTo",
        "placeholder": "coach@127sportsintensity.com",
        "type": "text",
        "secret": false,
        "description": "Same reply-to as 071/073"
      },
      {
        "name": "CUSTOM_WEBHOOK_URL_DEV",
        "placeholder": "REPLACE_WITH_DEV_CUSTOM_WEBHOOK_URL_OPS_ONLY",
        "type": "text",
        "secret": true,
        "description": "Generated by Custom webhook module — store only in Make + Airtable input ops. Never git."
      }
    ],
    "dataStore": {
      "name": "C025_117f_DEV_SendKeys",
      "keyField": "sendKey",
      "keyPattern": "ZOOM_REC_EMAIL|{enrollmentRid}|{zoomMeetingRid}",
      "fields": [
        { "name": "sendKey", "type": "text", "required": true },
        { "name": "status", "type": "text", "allowed": ["sent"] },
        { "name": "zoomAttendanceId", "type": "text" },
        { "name": "gmailMessageId", "type": "text" },
        { "name": "sentAt", "type": "text", "format": "ISO-8601" },
        { "name": "automationNumber", "type": "text", "value": "117f" },
        { "name": "templateKey", "type": "text", "value": "ZOOM_RECORDING_APPROVED" }
      ],
      "writeWhen": "Only after Gmail module succeeds",
      "duplicateBehavior": "Skip Gmail; Webhook response HTTP 200 status=already_sent"
    },
    "airtableTables": {
      "zoomAttendance": "Zoom Attendance",
      "enrollments": "Enrollments",
      "zoomMeetings": "Zoom Meetings"
    },
    "airtableFields": {
      "Zoom Attendance": [
        "Enrollment",
        "Zoom Meeting",
        "Attendance Method",
        "Recording Quiz Satisfactory?",
        "Zoom Credit Conflict?",
        "Enrollment RID",
        "Zoom Meeting RID",
        "Zoom XP Amount"
      ],
      "Enrollments": [
        "Parent Email - Cleaned",
        "Parent Email",
        "Parent First Name",
        "Full Athlete Name"
      ],
      "Zoom Meetings": [
        "Meeting Name",
        "Start Time",
        "Zoom Meeting Key",
        "Week"
      ]
    },
    "forbiddenWrites": [
      "XP Events",
      "Zoom Meetings.Attendees",
      "ZOOM_ATTEND_BASE|*",
      "Recording Approval Email Send Key (owned by 117f after 2xx)",
      "Recording Approval Email Sent At (owned by 117f after 2xx)"
    ],
    "email": {
      "subject": "Zoom Recording Quiz Approved for {Full Athlete Name}",
      "htmlSource": "make/lib/c025-117f-make-scenario.js → buildApprovalEmailHtml",
      "brand": {
        "primaryBlue": "#0034B7",
        "accentOrange": "#FF8B00",
        "lightGray": "#F2F2F2",
        "darkText": "#262626",
        "logoUrl": "https://make-021891587263-us-east-2-an.s3.us-east-2.amazonaws.com/BlueOrangeCircleLogo.png",
        "footer": "127 Sports Intensity",
        "signoff": "Coach Mike"
      }
    },
    "modules": [
      {
        "id": 1,
        "app": "Webhooks",
        "module": "Custom webhook",
        "purpose": "Receive 117f JSON; disable automatic 2xx — wait for Webhook response modules",
        "interface": [
          "automationNumber",
          "templateKey",
          "sendKey",
          "enrollmentRid",
          "zoomMeetingRid",
          "zoomAttendanceId",
          "timing"
        ]
      },
      {
        "id": 2,
        "app": "Flow control",
        "module": "Router",
        "purpose": "Validation gate",
        "branches": [
          {
            "name": "valid_payload",
            "filters": [
              { "field": "automationNumber", "operator": "equal", "value": "117f" },
              { "field": "templateKey", "operator": "equal", "value": "ZOOM_RECORDING_APPROVED" },
              { "field": "sendKey", "operator": "text:startsWith", "value": "ZOOM_REC_EMAIL|" },
              { "field": "enrollmentRid", "operator": "text:startsWith", "value": "rec" },
              { "field": "zoomMeetingRid", "operator": "text:startsWith", "value": "rec" },
              { "field": "zoomAttendanceId", "operator": "text:startsWith", "value": "rec" }
            ]
          },
          {
            "name": "invalid_payload",
            "filters": "fallback / else"
          }
        ]
      },
      {
        "id": 3,
        "app": "Webhooks",
        "module": "Webhook response",
        "branch": "invalid_payload",
        "configuration": {
          "status": 400,
          "body": {
            "status": "error",
            "error": "Invalid 117f payload (automationNumber, templateKey, sendKey, or record ids)"
          }
        }
      },
      {
        "id": 4,
        "app": "Data store",
        "module": "Get a record / Search records",
        "branch": "valid_payload",
        "configuration": {
          "dataStore": "C025_117f_DEV_SendKeys",
          "key": "{{1.sendKey}}"
        },
        "purpose": "Idempotency lookup"
      },
      {
        "id": 5,
        "app": "Flow control",
        "module": "Router",
        "purpose": "Duplicate vs new send",
        "branches": [
          {
            "name": "duplicate_sendKey",
            "filters": [
              { "field": "4.status", "operator": "equal", "value": "sent" }
            ]
          },
          {
            "name": "new_send",
            "filters": "else"
          }
        ]
      },
      {
        "id": 6,
        "app": "Webhooks",
        "module": "Webhook response",
        "branch": "duplicate_sendKey",
        "configuration": {
          "status": 200,
          "body": {
            "status": "already_sent",
            "sendKey": "{{1.sendKey}}",
            "automationNumber": "117f"
          }
        },
        "purpose": "Skip Gmail; allow 117f to stamp if needed"
      },
      {
        "id": 7,
        "app": "Airtable",
        "module": "Get a record",
        "branch": "new_send",
        "configuration": {
          "base": "appTetnuCZlCZdTCT",
          "table": "Zoom Attendance",
          "recordId": "{{1.zoomAttendanceId}}"
        }
      },
      {
        "id": 8,
        "app": "Airtable",
        "module": "Get a record",
        "configuration": {
          "base": "appTetnuCZlCZdTCT",
          "table": "Enrollments",
          "recordId": "{{1.enrollmentRid}}"
        }
      },
      {
        "id": 9,
        "app": "Airtable",
        "module": "Get a record",
        "configuration": {
          "base": "appTetnuCZlCZdTCT",
          "table": "Zoom Meetings",
          "recordId": "{{1.zoomMeetingRid}}"
        }
      },
      {
        "id": 10,
        "app": "Flow control",
        "module": "Router",
        "purpose": "Revalidate ZA + relationships + conflict",
        "branches": [
          {
            "name": "records_ok",
            "filters": [
              { "field": "7.Attendance Method", "operator": "equal", "value": "Recording Quiz" },
              { "field": "7.Recording Quiz Satisfactory?", "operator": "equal", "value": true },
              { "field": "7.Zoom Credit Conflict?", "operator": "notEqual", "value": 1 },
              { "note": "Enrollment/Meeting link IDs must contain payload enrollmentRid / zoomMeetingRid" }
            ]
          },
          {
            "name": "records_invalid",
            "filters": "else"
          }
        ]
      },
      {
        "id": 11,
        "app": "Webhooks",
        "module": "Webhook response",
        "branch": "records_invalid",
        "configuration": {
          "status": 422,
          "body": {
            "status": "error",
            "error": "Airtable revalidation failed (method, satisfactory, conflict, or relationship mismatch)"
          }
        }
      },
      {
        "id": 12,
        "app": "Flow control",
        "module": "Router",
        "branch": "records_ok",
        "purpose": "Recipient resolution",
        "branches": [
          {
            "name": "test_mode_ok",
            "filters": [
              { "field": "scenario.sendMode", "operator": "equal", "value": "test" },
              { "field": "scenario.testRecipientEmail", "operator": "notEqual", "value": "" },
              { "field": "scenario.testRecipientEmail", "operator": "notEqual", "value": "REPLACE_WITH_MIKE_CONTROLLED_TEST_INBOX" }
            ],
            "toEmail": "{{scenario.testRecipientEmail}}"
          },
          {
            "name": "live_mode_ok",
            "filters": [
              { "field": "scenario.sendMode", "operator": "equal", "value": "live" },
              { "note": "To = Parent Email - Cleaned else Parent Email; both blank → error" }
            ],
            "enabled": false,
            "note": "Keep disabled until Mike explicitly authorizes live recipient sends on DEV"
          },
          {
            "name": "recipient_missing",
            "filters": "else"
          }
        ]
      },
      {
        "id": 13,
        "app": "Webhooks",
        "module": "Webhook response",
        "branch": "recipient_missing",
        "configuration": {
          "status": 422,
          "body": {
            "status": "error",
            "error": "Missing recipient (configure Mike test inbox for sendMode=test)"
          }
        }
      },
      {
        "id": 14,
        "app": "Tools",
        "module": "Compose a string / Set variables",
        "branch": "test_mode_ok",
        "purpose": "Build subject + HTML from make/lib/c025-117f-make-scenario.js buildApprovalEmailHtml output",
        "subjectTemplate": "Zoom Recording Quiz Approved for {{8.Full Athlete Name}}",
        "htmlTemplateSource": "Paste HTML from offline helper buildApprovalEmailHtml (071 brand shell)"
      },
      {
        "id": 15,
        "app": "Gmail",
        "module": "Send an email",
        "configuration": {
          "to": "{{scenario.testRecipientEmail}}",
          "replyTo": "{{scenario.replyTo}}",
          "subject": "{{14.subject}}",
          "contentType": "HTML",
          "body": "{{14.html}}",
          "note": "DEV test mode only — never map Parent Email fields to To while sendMode=test"
        },
        "errorRoute": {
          "id": 16,
          "module": "Webhook response",
          "status": 502,
          "body": { "status": "error", "error": "Gmail send failed" },
          "dataStoreWrite": false
        }
      },
      {
        "id": 17,
        "app": "Data store",
        "module": "Add/replace a record",
        "configuration": {
          "dataStore": "C025_117f_DEV_SendKeys",
          "key": "{{1.sendKey}}",
          "record": {
            "sendKey": "{{1.sendKey}}",
            "status": "sent",
            "zoomAttendanceId": "{{1.zoomAttendanceId}}",
            "gmailMessageId": "{{15.messageId}}",
            "sentAt": "{{now}}",
            "automationNumber": "117f",
            "templateKey": "ZOOM_RECORDING_APPROVED"
          }
        },
        "purpose": "Only after Gmail success"
      },
      {
        "id": 18,
        "app": "Webhooks",
        "module": "Webhook response",
        "configuration": {
          "status": 200,
          "body": {
            "status": "sent",
            "sendKey": "{{1.sendKey}}",
            "automationNumber": "117f"
          }
        },
        "purpose": "2xx only after Gmail + Data Store success write"
      }
    ]
  },
  "antiPatterns": [
    "Early webhook 2xx before Gmail",
    "Data Store write before Gmail success",
    "Mapping Parent Email to To while sendMode=test",
    "Committing CUSTOM_WEBHOOK_URL_DEV or real testRecipientEmail",
    "Airtable writes to XP Events or Attendees",
    "Pointing scenario at PROD base appn84sqPw03zEbTT",
    "Enabling scenario before Mike review"
  ]
}
